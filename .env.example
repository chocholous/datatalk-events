# Application
APP_NAME="DataTalk Events"
DEBUG=false

# Database
DATABASE_URL="sqlite:///data/app.db"

# Scraping
SCRAPE_URL="https://datatalk.cz/kalendar-akci/"
SCRAPE_SCHEDULE="0 8 * * 1"

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Telegram
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHANNEL_ID=""  # e.g. @datatalk_events

# Google Calendar
GOOGLE_CALENDAR_ID=""  # Calendar ID to sync events to
GOOGLE_SERVICE_ACCOUNT_JSON=""  # Service account JSON (single line)

# Security
SECRET_KEY=""  # Set a strong random secret for production
WEBHOOK_URL="http://localhost:8000"

# Admin
ADMIN_USERNAME="admin"
ADMIN_PASSWORD=""  # Set a strong password for production
